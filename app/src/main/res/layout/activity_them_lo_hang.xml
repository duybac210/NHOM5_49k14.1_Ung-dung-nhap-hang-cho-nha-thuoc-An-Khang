<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#34D058"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="4dp"
            android:src="@drawable/ic_back"
            android:contentDescription="Quay lại"
            app:tint="@color/black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Thêm lô hàng"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thông tin lô hàng"
                android:textColor="#333333"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- Khung trắng với shadow nhẹ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:strokeWidth="1dp"
                app:strokeColor="#EEEEEE"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Dropdown Chọn thuốc -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tên thuốc" android:textStyle="bold" android:textColor="#000000" android:textSize="13sp"/>
                        <Spinner
                            android:id="@+id/spnProductPicker"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_field_outline"
                            android:layout_marginTop="6dp"
                            android:contentDescription="Chọn thuốc trong đơn"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0"/>

                    <!-- Lịch: NSX | HSD -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:padding="12dp"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ngày sản xuất" android:textStyle="bold" android:textColor="#000000" android:textSize="13sp"/>
                            <EditText
                                android:id="@+id/etMfgDate"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_field_outline"
                                android:layout_marginTop="6dp"
                                android:paddingHorizontal="12dp"
                                android:focusable="false"
                                android:clickable="true"
                                android:drawableEnd="@drawable/ic_calendar"
                                android:hint="DD/MM/YYYY"
                                android:textSize="13sp"/>
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#F0F0F0"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:padding="12dp"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hạn sử dụng *" android:textStyle="bold" android:textColor="#000000" android:textSize="13sp"/>
                            <EditText
                                android:id="@+id/etExpDate"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:background="@drawable/bg_field_outline"
                                android:layout_marginTop="6dp"
                                android:paddingHorizontal="12dp"
                                android:focusable="false"
                                android:clickable="true"
                                android:drawableEnd="@drawable/ic_calendar"
                                android:textSize="13sp"
                                android:hint="Bắt buộc"
                                android:textColorHint="#E53935"/>
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0"/>

                    <!-- Số lượng - Đã xóa đơn giá nhập -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Số lượng" android:textStyle="bold" android:textColor="#000000" android:textSize="13sp"/>
                        <EditText
                            android:id="@+id/etQuantity"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_field_outline"
                            android:layout_marginTop="6dp"
                            android:paddingHorizontal="12dp"
                            android:inputType="number"
                            android:textSize="13sp"
                            android:hint="Nhập số lượng"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Nút Lưu / Bỏ qua -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:gravity="end"
        android:orientation="horizontal"
        android:padding="16dp">

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Bỏ qua"
            android:textAllCaps="false"
            android:backgroundTint="@color/white"
            android:textColor="@color/black"
            app:strokeColor="@color/black"
            app:strokeWidth="1dp"
            app:cornerRadius="5dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:backgroundTint="#34D058"
            android:text="Lưu"
            android:textAllCaps="false"
            android:textColor="@color/black"
            app:cornerRadius="5dp" />
    </LinearLayout>

    <include layout="@layout/layout_mock_footer_nav" />
</LinearLayout>
